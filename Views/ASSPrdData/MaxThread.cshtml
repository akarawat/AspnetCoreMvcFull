@{
  ViewData["Title"] = "Max Thread";
}

@{
    var isFullscreen = ViewData["isFullscreen"]?.ToString() == "true";
    var navbarType = isFullscreen ? "layout-navbar-hidden" : "layout-navbar-fixed";
    var menuFixed = isFullscreen ? "" : "menu-fixed";
    var isNavbar = isFullscreen ? false : true;
    var isMenu = isFullscreen ? false : true;
    var strCaption = isFullscreen ? "Exit full screen" : "Full screen";
    //ViewData["navbarHideToggle"] = true;
    // *** No Menus ***
    ViewData["isMenu"] = isMenu;
    ViewData["menuFixed"] = menuFixed;
    // *** No Navbar ***
    ViewData["isNavbar"] = isNavbar;
    ViewData["navbarType"] = navbarType;

}

@section VendorScripts {

    <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/datatables.js"></script>
    <script src="~/js/datatables.min.js"></script>


    @* <script src="~/js/moment.js"></script> *@

    @* <script src="~/js/form-basic-inputs.js"></script> *@
    @* <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script> *@

    <!-- Chart.js -->
    <script src="~/js/chart.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> *@

    <!-- Luxon Date Library -->
    <script src="~/js/luxon.min.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/luxon@3/build/global/luxon.min.js"></script> *@

<!-- Chart.js Luxon Adapter -->
    <script src="~/js/chartjs-adapter-luxon@1.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1"></script> *@

    <script src="~/js/chart.umd.min.js"></script>
    <script src="~/js/index.umd.min.js"></script>

}

@section PageStyles {
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/maxthread_chart.css" rel="stylesheet" />
}

@* ************** Content ************** *@
<div class="row g-8 mb-8">
  <!-- Criteria Header -->
  <div class="card">
    
    <div class="card-body">
            <input type="text" id="txtSerial" class="form-control" style="display:none" />
            <input type="hidden" id="ddlSeries" class="form-control" />
            <button onclick="viewThreadDataTable()" class="" style="display:none">View Data</button>
      <!-- Scatter chart -->
      <div class="row mb-3">
          <div class="col-md-6">
              <a href="/">
                  <i class="ri-arrow-left-circle-line"></i>Home
              </a>
                    <button id="btnB3" class="btn btn-light h-20" type="button" onclick="callFuncButton('3');">B3</button>
                    <button id="btnB4" class="btn btn-light h-20" type="button" onclick="callFuncButton('4');">B4</button>
                    <button id="btnB5" class="btn btn-light h-20" type="button" onclick="callFuncButton('5');">B5</button>
                    <button id="btnB7" class="btn btn-light h-20" type="button" onclick="callFuncButton('7');">B7</button>
                    <button id="btnB9P" class="btn btn-light h-20" type="button" onclick="callFuncButton('9 PAM');">B9 PAM</button>
                    <button id="btnB9S" class="btn btn-light h-20" type="button" onclick="callFuncButton('9 Socle');">B9 Socle</button>
                    <h5 class="card-header" itemid="title_msg">Max thread cutting <span id="lblSeries" class="text-bold"></span></h5>

                    <small class="text-light fw-medium d-block">Data range</small>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="criteria" id="criteria2" value="option2" onclick="loadThreadCutChart('W')" />
                        <label class="form-check-label" for="criteria2">Week</label>
                    </div>
                    <div class="form-check form-check-inline mt-4">
                        <input class="form-check-input" type="radio" name="criteria" id="criteria3" value="option1" onclick="loadThreadCutChart('M')" />
                        <label class="form-check-label" for="criteria3">Month</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="criteria" id="criteria4" value="option2" onclick="loadThreadCutChart('HY')" />
                        <label class="form-check-label" for="criteria4">Halfyear</label>
                    </div>
          </div>
          <div class="col-md-4">
            <div class="row">
              <div class="col-sm-6">
                <label>From</label>
                <input type="date" id="fromDate" class="form-control" />
              </div>
              <div class="col-sm-6">
                <label>To</label>
                <input type="date" id="toDate" class="form-control" />
              </div>
            </div>
          </div>
          
          <div class="col-md-2 align-items-center"> &nbsp; 
            <button onclick="loadThreadCutChart()" class="btn btn-primary w-100">Search</button> <br/> &nbsp;
                    <button class="btn btn-success w-100" type="button" id="btnExport" style="display:block !important;">EXPORT</button>  &nbsp;
            <button class="btn btn-info w-100" type="button" id="btnRemark">Remark</button> 
          </div>
      </div>
      <!-- Scatter chart -->
      <div class="row mb-3">
          <div class="col-md-10">
            <canvas id="cutCurrentChart" height="120"></canvas>
          </div>
          <div class="col-md-2">
            <span id="lblSummaryTest">✅ Summary test result</span> <br />
            <span id="lblTotalTest">Total [0]</span> <br />
            <span id="lblTotalClosetoCut">Total close to max [0]</span><br />
            <span id="lblTotalMaxCut">Total max cut [0]</span><br />
            <span id="lblTotalNormalCut">Total normal cut [0]</span>
            <span id="lblPrdYeild"></span>

            <!-- Start Param Pass/Fail -->

            <div class="card shadow-lg-hover mt-4">
                <div class="card-header">
                    Max/Min Parameter
                </div>
                <div class="card-body">
                    <blockquote class="blockquote mb-0">
                        Model:<label id="lblCfgSeries">-</label> <label id="lblCfgMnuFunc">-</label>
                        <br />
                        Max:<label id="lblMaxFail">0</label> Min:<label id="lblMinFail">0</label>
                        <br />Cutter:<label id="lblCountMaxFail">0</label> Normal:<label id="lblCountMinFail">0</label>
                        <footer>
                            <button class="btn btn-sm btn-secondary" type="button" id="btnCfgMaxMin">
                              <i class="arrow-right-up-box-line text-info"></i>Max/Min
                            </button>
                        </footer>
                    </blockquote>
                </div>
            </div>
            <!-- End Param Pass/Fail -->

          </div>
      </div>
      

      <div class="row mb-3">
          <div class="col-md-12">
            <div class="card-body">
                <p class="text-end">
                  <span style="font-size:0.9rem;color:#666" id="spanNormalCut"> </span><span id="spanNormColor" class="text-danger"></span>
                  <span style="font-size:0.9rem;color:#666" id="spanCutMaxWarn"></span><span id="spanWarnColor" class="text-warning"></span>
                  <span style="font-size:0.9rem;color:#666" id="spanCutMaxAlarm"></span><span id="spanCutColor" class="text-danger"></span>
                </p>
                <p class="text-end">
                  <span style="font-size:0.9rem;color:#666" id="spanPrdYeild"></span>
                    <span id="spanYeildFormular"></span>
                </p>
                <table id="bindDataTable" class="table table-striped table-bordered dt-responsive" width="100%">
                    <thead>
                        <tr>
                            <th>Date.</th>
                            <th>Serial</th>
                            <th>Max Cur.Normal</th>
                            <th>Tol.Normal</th>
                            <th>Max Cur.Cutter</th>
                            <th>Tol.Cutter</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>	
          </div>
      </div>

      @* Bar Chart *@
      
      <div class="row" style="display:none">
        <div class="col-8">
          <canvas id="threadCutChart" height="200"></canvas>
        </div>
        <div class="col-4">
          @* Table EFF *@
          <div class="card-content">
            <div class="card-header">
                <h5 class="TableTextSize">Thread cutting efficiency data</h5>
            </div>
            <div class="card-body">
                <table id="bindEffDataTable" class="table table-striped table-bordered" width="100%">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Fail Normal</th>
                            <th>Fail Cutter</th>
                            <th>Total</th>
                            <th>Eff</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="card-footer">
              
            </div>
        </div>
        </div>
      </div>

      <div class="card" id="div_box_plot" style="display:none">
          <h5 class="card-header" itemid="title_msg">BOX Plot Max thread cutting</h5>
          <div class="card-body">

              <!-- Box plot chart -->
              <canvas id="myBoxPlotChart"></canvas>
              <!-- /Box Plot chart -->

          </div>
          <div class="card-footer">
              <table id="bindBoxPlotDataTable" class="table table-striped table-bordered" width="100%">
                  <thead>
                      <tr>
                          <th>Date</th>
                          <th>Fail Normal</th>
                          <th>Fail Cutter</th>
                          <th>Total</th>
                          @* <th>Eff</th>
                          <th>Eff</th> *@
                      </tr>
                  </thead>
              </table>
          </div>
      </div>
      

    </div>
  </div>
</div>


<div class="layout-demo-info">
    <button class="btn btn-outline-secondary" id="toggleFullscreenBtn">
        <i class="bx bx-fullscreen"></i> @strCaption
    </button>
    <button class="" id="BtnBoxPlot" style="display:none">
        <i class="bx bx-fullscreen"></i> Box plot 
    </button>
</div>


<!-- Modal Loading -->
<div class="modal fade" id="loadingModal"
  tabindex="-1" aria-labelledby="loadingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <img src="~/img/loading200w.gif" />
            </div>
            <div class="modal-footer">

            </div>
        </div>
    </div>
</div>
<!-- Modal Data Scatter -->
<div class="modal fade" id="scatterDataTableModal"
     tabindex="-1" aria-labelledby="loadingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Thread cutting data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table id="bindDataTable2_" class="table table-striped table-bordered dt-responsive" width="100%">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Serial</th>
                            <th>Max Cur.Normal</th>
                            <th>Tol.Normal</th>
                            <th>Max Cur.Cutter</th>
                            <th>Tol.Cutter</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>


<!-- Modal Remark -->
<div class="modal fade" id="remarkModal"
     tabindex="-1" aria-labelledby="remarkModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <div class="row mb-3">
                    <div class="col-md-12">
                        <input type="hidden" id="trid" />
                        <label>Add Remark</label>
                        <textarea id="txtRemark" class="form-control" rows="3"></textarea>
                        <button type="button" id="btnAddRemark">Add Remark</button>
                        <button type="button" id="btnUpdateRemark" style="display:none">Update Remark</button>
                    </div>
                </div>
                <table id="bindDataTableRemark" class="table table-striped table-bordered dt-responsive" width="100%">
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>

<!-- Modal Min/Max Fail -->
<div class="modal fade" id="cfgMaxMinModal"
     tabindex="-1" aria-labelledby="cfgMaxMinModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <label>Edit Max/Min Fail</label>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <input class="form-control" type="number" placeholder="10" id="txtMaxFail" />
                        <label for="txtMaxFail">Maximum fail</label>
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" type="number" placeholder="-10" id="txtMinFail" />
                        <label for="txtMinFail">Minimun fail</label>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <button class="btn btn-sm btn-success" type="button" id="btnUpdateCfgMaxMin">Update Max/Min</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>


@section PageScripts {
    
    <script src="~/js/site.js?v=1.0.001"></script>
    <script src="~/js/maxthread_chart.js?v=@DateTime.Now.ToString("ddmmmyyyyHHmmss")"></script>

    <script src="~/js/xlsx.full.min.js"></script>
    <script src="~/js/jszip.min.js"></script>

    <script src="~/js/boxplot.js?v=@DateTime.Now.ToString("ddmmmyyyyHHmmss")"></script>
}
