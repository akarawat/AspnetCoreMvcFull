            <div class="modal-footer">
                <a href="javascript:void(0);" class="btn btn-sm btn-info" data-bs-dismiss="modal">OK</a>
                <a href="javascript:void(0);" class="btn btn-sm btn-warning" data-bs-dismiss="modal">CANCEL</a>
