@{
  ViewData["Title"] = "B4 Model Data";
}

@* ************** Content ************** *@
<div class="row g-12 mb-12">
  <!-- Criteria Header -->
    <div class="card">
      <h5 class="card-header">B9 Model</h5>
      <div class="card-body">
        <div class="row row-bordered g-0">
          <div class="col-md-6">
            <div class="row">
              <hr />
              <div class="form-floating form-floating-outline col-md-3">
                <input class="form-control" type="date" id="dateStart" />
                <label for="dateStart">Date Start</label>
              </div>
              <div class="form-floating form-floating-outline col-md-3">
                <input class="form-control" type="date" id="dateEnd" />
                <label for="dateEnd">Date End</label>
              </div>
            </div>
          </div>
          <div class="col-md-2 text-center">
            <a href="javascript:ModalSeries();" class="btn btn-outline-primary">Series <i class="ri-arrow-down-s-line"></i></a> 
          </div>
                <div class="col-md-2 text-center"><a href="javascript:ModalMachine();" class="btn btn-outline-primary">Machine <i class="ri-arrow-down-s-line"></i></a></div>
                <div class="col-md-2 text-center"><a href="javascript:ModalCurrent();" class="btn btn-outline-primary">Current <i class="ri-arrow-down-s-line"></i></a></div>
            </div>

        <div class="row">
          <div class="col-md-12">
            <div class="divider divider-dashed">
              <div class="divider-text"></div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-8">
            <!-- Main Scatter chart -->
            <div>
                <canvas id="myChart"></canvas>
            </div>

            

          </div>
          <div class="col-md-4">
            <!-- Main Dataset -->
            Dataset
          </div>
        </div>
      </div>
    </div>
</div>

<!-- Modal Dropdown -->
<div class="modal fade" id="modalSeries" tabindex="-1" aria-labelledby="modalSeriesLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalSeriesLabel">Series</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div class="row">
                    <div class="col-md-6">

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                All
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 3
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 4
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 5
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 7
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 9
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3" checked />
                            <label class="form-check-label" for="defaultCheck3">
                                Series 9 Socle
                            </label>
                        </div>

                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <a href="javascript:void(0);" class="btn btn-sm btn-info" data-bs-dismiss="modal">OK</a>
                <a href="javascript:void(0);" class="btn btn-sm btn-warning" data-bs-dismiss="modal">CANCEL</a>
            </div>
        </div>
    </div>
</div>
