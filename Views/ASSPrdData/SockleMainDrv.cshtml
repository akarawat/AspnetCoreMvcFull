@{
  ViewData["Title"] = "B4 Model Data";
}

@section PageScripts {
    <script src="~/js/moment.js"></script>
    
    <script src="~/js/form-basic-inputs.js"></script>
    <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script> 

    <script src="~/js/chart.js"></script>
    

    <script src="~/js/datatables.js"></script> 
    <script src="~/js/datatables.min.js"></script>

    <script src="~/js/datatables2.2.0.js"></script>

    <!-- ส่วนสำคัญสำหรับปุ่ม Export -->
    <script src="~/js/dataTables.buttons.min.js"></script>
    <script src="~/js/jszip.min.js"></script>
    <script src="~/js/buttons.html5.min.js"></script>

    @* <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> 
        <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>*@
    <script src="~/js/socklemaindrv.js"></script>


}

@* ************** Content ************** *@
<div class="row g-12 mb-12">
  <!-- Criteria Header -->
    <div class="card">
      <h5 class="card-header" itemid="title_msg">Sockle Main Drive</h5>
      <div class="card-body">
        <div class="row row-bordered g-0" style="display:block">
          <div class="col-md-9">
            <div class="row">
              <hr />
              <div class="form-floating form-floating-outline col-md-3">
                <input class="form-control" type="date" id="dateStart" />
                <label for="dateStart">Date Start</label>
              </div>
              <div class="form-floating form-floating-outline col-md-3">
                <input class="form-control" type="date" id="dateEnd" />
                <label for="dateEnd">Date End</label>
              </div>
              <div class="form-floating form-floating-outline col-md-3">
                <button type="button" class="btn btn-primary" onclick="GetSearch()">Search</button>
              </div>

            </div>
          </div>
          <div class="col-md-2 text-center">
          </div>
          <div class="col-md-2 text-center">
          </div>
        </div>

        <div class="row">
          <div class="col-md-12">
            <div class="divider divider-dashed">
              <div class="divider-text"></div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-12">
            <!-- Main Scatter chart -->
            <div>
                @* <canvas id="myChart"></canvas> *@
                <canvas id="myChart" width="800" height="400"></canvas>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-12">
            <!-- Main Dataset -->
            <div class="table-responsive">
                <table id="bindDataTable" class="table table-striped table-bordered dt-responsive" width="100%">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Serial No</th>
                            <th>Method</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
          </div>
        </div>
      </div>
    </div>
</div>


<!-- Modal Loading -->
<div class="modal fade" id="loadingModal"
  tabindex="-1" aria-labelledby="loadingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <img src="~/img/loading200w.gif" />
            </div>
            <div class="modal-footer">

            </div>
        </div>
    </div>
</div>
