@model List<AspnetCoreMvcFull.Models.PassFailModel>
@{
    ViewData["Title"] = "Machine KPI Configuration";
}
@{
    //Layout = "_BlankLayout";
    var isFullscreen = ViewData["isFullscreen"]?.ToString() == "false";
    if (isFullscreen)
    {
      Layout = "_BlankLayout";
    }
    var navbarType = isFullscreen ? "layout-navbar-hidden" : "layout-navbar-fixed";
    var menuFixed = isFullscreen ? "" : "menu-fixed";
    var isNavbar = isFullscreen ? false : true;
    var isMenu = isFullscreen ? false : true;
    var strCaption = isFullscreen ? "Exit full screen" : "Full screen";
    //ViewData["navbarHideToggle"] = true;
    // *** No Menus ***
    ViewData["isMenu"] = isMenu;
    ViewData["menuFixed"] = menuFixed;
    // *** No Navbar ***
    ViewData["isNavbar"] = isNavbar;
    ViewData["navbarType"] = navbarType;
}

@section VendorStyles {
    <link href="~/css/site.css" rel="stylesheet" />
}

@section VendorScripts {
    <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script>
}

@* ************** Content ************** *@
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="container mt-4">
    <h3 class="mb-3">🔧 Edit Pass Fail Parameters</h3>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Model (3,4,5)</th>
                <th>Menu Function</th>
                <th>Max Fail</th>
                <th>Min Fail</th>
                <th>Param 1 (Option)</th>
                <th>Param 2 (Option)</th>
                <th>Param 3 (Option)</th>
                <th>Param 4 (Option)</th>
                <th>Param 5 (Option)</th>
                <th>Param Remarks (Option)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr class="bg-info">
                <td><input id="input_0" class="form-control form-control-sm" /></td>
                <td><input id="input_1" class="form-control form-control-sm" /></td>
                <td><input id="input_2" class="form-control form-control-sm" /></td>
                <td><input id="input_3" class="form-control form-control-sm" /></td>
                <td><input id="input_4" class="form-control form-control-sm" /></td>
                <td><input id="input_5" class="form-control form-control-sm" /></td>
                <td><input id="input_6" class="form-control form-control-sm" /></td>
                <td><input id="input_7" class="form-control form-control-sm" /></td>
                <td><input id="input_8" class="form-control form-control-sm" /></td>
                <td><textarea id="input_11" class="form-control form-control-sm" cols="70"></textarea></td>
                <td>
                    <button class="btn btn-info btn-sm btnSave">💾 Add</button>
                </td>
            </tr>
            @foreach (var item in Model)
            {
                <tr data-id="@item.id">
                    <td><input class="form-control form-control-sm" value="@item.series" disabled /></td>
                    <td><input class="form-control form-control-sm" value="@item.mnufunc" /></td>
                    <td><input class="form-control form-control-sm" value="@item.max_fail" /></td>
                    <td><input class="form-control form-control-sm" value="@item.min_fail" /></td>
                    <td><input class="form-control form-control-sm" value="@item.param_1" /></td>
                    <td><input class="form-control form-control-sm" value="@item.param_2" /></td>
                    <td><input class="form-control form-control-sm" value="@item.param_3" /></td>
                    <td><input class="form-control form-control-sm" value="@item.param_4" /></td>
                    <td><input class="form-control form-control-sm" value="@item.param_5" /></td>
                    <td><textarea class="form-control form-control-sm" cols="70">@item.remarks</textarea></td>
                    <td>
                        <i class="btnUpdate ri-file-add-line cursor-pointer text-success fs-6">Update</i>
                        <i class="btnDelete ri-file-excel-line cursor-pointer text-danger fs-6">Del</i>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="layout-demo-info">
    <button class="btn btn-outline-secondary" id="toggleFullscreenBtn">
        <i class="bx bx-fullscreen"></i> @strCaption
    </button>
    <button class="" id="BtnBoxPlot" style="display:none">
        <i class="bx bx-fullscreen"></i> Box plot 
    </button>
</div>

</div>

@section PageScripts {
    <script src="~/js/passfailconfig.js"></script>
}
