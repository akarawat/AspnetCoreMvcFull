<div class="layout-demo-info">
    <button class="btn btn-outline-secondary" id="toggleFullscreenBtn">
        <i class="bx bx-fullscreen"></i> @strCaption
    </button>
    <button class="" id="BtnBoxPlot" style="display:none">
        <i class="bx bx-fullscreen"></i> Box plot 
    </button>
</div>


<!-- Modal Remark -->
<div class="modal fade" id="remarkModal"
     tabindex="-1" aria-labelledby="remarkModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <div class="row mb-3">
                    <div class="col-md-12">
                        <input type="hidden" id="trid"/>
                        <label>Add Remark</label>
                        <textarea id="txtRemark" class="form-control" rows="3"></textarea>
                        <button type="button" id="btnAddRemark">Add Remark</button>
                        <button type="button" id="btnUpdateRemark" style="display:none">Update Remark</button>
                    </div>
                </div>
                <table id="bindDataTableRemark" class="table table-striped table-bordered dt-responsive" width="100%">
                    <tbody>
                        <tr>
                            <td></td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>

<!-- Modal Loading -->
<div class="modal fade" id="loadingModal"
  tabindex="-1" aria-labelledby="loadingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <img src="~/img/loading200w.gif" />
            </div>
            <div class="modal-footer">

            </div>
        </div>
    </div>
</div>

<!-- Modal Min/Max Fail -->
<div class="modal fade" id="cfgMaxMinModal"
     tabindex="-1" aria-labelledby="cfgMaxMinModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body tdVarAlign">
                <label>Edit Max/Min Fail</label>
                <input type="hidden" id="hidParam_1" />
                <label class="text-dark" id="lblParam_1"></label>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <input class="form-control" type="number" placeholder="-10" id="txtMinFail" />
                        <label for="txtMinFail">Minimun</label>
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" type="number" placeholder="10" id="txtMaxFail" />
                        <label for="txtMaxFail">Maximum</label>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <button class="btn btn-sm btn-success" type="button" id="btnUpdateCfgMaxMin">Update Max/Min</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>

