@{
  ViewData["Title"] = "Apparatus Thread Tension";
}

@{
    var isFullscreen = ViewData["isFullscreen"]?.ToString() == "true";
    var navbarType = isFullscreen ? "layout-navbar-hidden" : "layout-navbar-fixed";
    var menuFixed = isFullscreen ? "" : "menu-fixed";
    var isNavbar = isFullscreen ? false : true;
    var isMenu = isFullscreen ? false : true;
    var strCaption = isFullscreen ? "Exit full screen" : "Full screen";
    //ViewData["navbarHideToggle"] = true;
    // *** No Menus ***
    ViewData["isMenu"] = isMenu;
    ViewData["menuFixed"] = menuFixed;
    // *** No Navbar ***
    ViewData["isNavbar"] = isNavbar;
    ViewData["navbarType"] = navbarType;

}

@section VendorScripts {

    <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/datatables.js"></script>
    <script src="~/js/datatables.min.js"></script>


    <script src="~/js/moment.js"></script>

    @* <script src="~/js/form-basic-inputs.js"></script> *@
    @* <script src="~/js/jquery.js"></script>
    <script src="~/js/jquery.min.js"></script> *@

    <!-- Chart.js -->
    <script src="~/js/chart.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> *@

    <!-- Luxon Date Library -->
    <script src="~/js/luxon.min.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/luxon@3/build/global/luxon.min.js"></script> *@

<!-- Chart.js Luxon Adapter -->
    <script src="~/js/chartjs-adapter-luxon@1.js"></script>
@* <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1"></script> *@

    <script src="~/js/chart.umd.min.js"></script>
    <script src="~/js/index.umd.min.js"></script>

}

@section PageStyles {
    <link href="~/css/tta.css?v=1.0.100" rel="stylesheet" />
}

@* ************** Content ************** *@
<div class="row g-8 mb-8">
  <!-- Criteria Header -->
  <div class="card">
    
    <div class="card-body">
      <input type="hidden" id="txtSerial" class="form-control" style="display:none" />
      <input type="hidden" id="ddlSeries" class="form-control" />
      <button onclick="viewThreadDataTable()" class="" style="display:none">View Data</button>
      <!-- Scatter chart -->
      <div class="row mb-3">
          <div class="col-md-6">
            <!-- Start Header -->
            <a href="/">
                <i class="ri-arrow-left-circle-line"></i>Home
            </a>
            <button id="btnB3" class="btn btn-light h-20" type="button" onclick="callFuncButton('3');">B3</button>
            <button id="btnB4" class="btn btn-light h-20" type="button" onclick="callFuncButton('4');">B4</button>
            <button id="btnB5" class="btn btn-light h-20" type="button" onclick="callFuncButton('5');">B5</button>
            <button id="btnB7" class="btn btn-light h-20" type="button" onclick="callFuncButton('7');">B7</button>
            <button id="btnB9P" class="btn btn-light h-20" type="button" onclick="callFuncButton('9');">B9</button>
            <button id="btnB9S" class="btn btn-light h-20" type="button" onclick="callFuncButton('9 Socle');">B9 Socle</button>
            @* <label>Serial</label> *@
            <h5 class="card-header" id="title_msg">@ViewData["Title"] <span id="lblSeries" class="text-bold"></span></h5>

            <small class="text-light fw-medium d-block">Data range</small>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="criteria" id="criteria1" value="1" onclick="loadmeasureChartLower('D'); loadTTABoxPlot('D')" />
                <label class="form-check-label" for="criteria1">Daily</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="criteria" id="criteria2" value="2" onclick="loadmeasureChartLower('W'); loadTTABoxPlot('W')" />
                <label class="form-check-label" for="criteria2">Week</label>
            </div>
            <div class="form-check form-check-inline mt-4">
                <input class="form-check-input" type="radio" name="criteria" id="criteria3" value="3" onclick="loadmeasureChartLower('M'); loadTTABoxPlot('M')" />
                <label class="form-check-label" for="criteria3">Month</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="criteria" id="criteria4" value="4" onclick="loadmeasureChartLower('HY'); loadTTABoxPlot('HY')" />
                <label class="form-check-label" for="criteria4">Halfyear</label>
            </div>

            <!-- Stop Header -->
              
          </div>

          <div class="col-md-4">
            <div class="row">
              <div class="col-sm-6">
                <label>From</label>
                <input type="date" id="fromDate" class="form-control" />
              </div>
              <div class="col-sm-6">
                <label>To</label>
                <input type="date" id="toDate" class="form-control" />
              </div>
            </div>
          </div>
          
          <div class="col-md-2 align-items-center"> &nbsp; 
              <button onclick="loadmeasureChartLower(); loadTTABoxPlot();" class="btn btn-primary w-100">Search</button> &nbsp; 
              <button class="btn btn-success w-100" type="button" id="btnExport">EXPORT</button> &nbsp; 
              <button class="btn btn-info w-100" type="button" id="btnRemark">Remark</button>
          </div>
      </div>

      <div class="row border-1" id="infoCol1">
          <div class="col-md-12 border-1">
              <div class="row">
                  <div class="col-10 border-1">
                      <label id="lblDiffBoxplot">Differance</label>
                      <canvas id="ttaBoxPlotChart"></canvas>
                  </div>
                  <div class="col-2 border-1 mt-8">
                      <div class="row" style="display:block">
                          <div class="col-md-12">
                              <!-- Start Param Pass/Fail Differance -->
                              <div class="card shadow-lg-hover mt-5">
                                  <div class="card-header">
                                      Max/Min Parameter
                                  </div>
                                  <div class="card-body">
                                      <blockquote class="blockquote mb-0">
                                          Model:<label id="lblCfgSeries">-</label> <label id="lblCfgMnuFunc">-</label>
                                          <br />
                                          Min:<label id="lblMinFail">0</label> Max:<label id="lblMaxFail">0</label> 
                                          <br />
                                          <footer>
                                              <button class="btn btn-sm btn-secondary" type="button" id="btnCfgMaxMin" style="display:block !important;" onclick="SetMaxMinParameter('Diff');">
                                                  <i class="arrow-right-up-box-line text-info"></i>Max/Min
                                              </button>
                                          </footer>
                                      </blockquote>
                                  </div>
                              </div>
                              <!-- End Param Pass/Fail -->
                          </div>
                      </div>
                  </div>
              </div>
              <div class="row border mb-3 p-2" style="background-color: #f8f9fa;">
                  <div class="col-5">
                      <label id="lblLowerBoxplot">Lower Boxplot</label>
                      <canvas id="ttaLowBoxPlotChart"></canvas>
                  </div>
                  <div class="col-5">
                      <label id="lblLowerOffBoxplot">Lower Offset</label>
                      <canvas id="ttaLowOffBoxPlotChart"></canvas>
                  </div>
                  <div class="col-2 border-1 mt-8">
                      <div class="row" style="display:block">
                          <div class="col-md-12">
                              <!-- Start Param Pass/Fail Lower -->
                              <div class="card shadow-lg-hover mt-5">
                                  <div class="card-header">
                                      Lower Max/Min Parameter
                                  </div>
                                  <div class="card-body">
                                      <blockquote class="blockquote mb-0">
                                          Model:<label id="lblCfgSeriesLower">-</label>
                                          <br />
                                          Min:<label id="lblMinFailLower">0</label> Max:<label id="lblMaxFailLower">0</label> 
                                          <br />
                                          <footer>
                                              <button class="btn btn-sm btn-secondary" type="button" id="btnCfgMaxMinLower" style="display:block !important;" onclick="SetMaxMinParameter('Lower');">
                                                  <i class="arrow-right-up-box-line text-info"></i>Max/Min
                                              </button>
                                          </footer>
                                      </blockquote>
                                  </div>
                              </div>
                              <!-- End Param Pass/Fail -->
                          </div>
                      </div>
                  </div>
              </div>
              <div class="row border mb-3 p-2" style="background-color: #f8f9fa;">
                  <div class="col-5">
                      <label id="lblHierBoxplot">Higher Boxplot</label>
                      <canvas id="ttaHierBoxPlotChart"></canvas>
                  </div>
                  <div class="col-5">
                      <label id="lblHierOffBoxplot">Higher Offset</label>
                      <canvas id="ttaHierOffBoxPlotChart"></canvas>
                  </div>
                  <div class="col-2 border-1 mt-8">
                      <div class="row" style="display:block">
                          <div class="col-md-12">
                              <!-- Start Param Pass/Fail Higher -->
                              <div class="card shadow-lg-hover mt-5">
                                  <div class="card-header">
                                      Higher Max/Min Parameter
                                  </div>
                                  <div class="card-body">
                                      <blockquote class="blockquote mb-0">
                                          Model:<label id="lblCfgSeriesHigher">-</label>
                                          <br />
                                          Min:<label id="lblMinFailHigher">0</label> Max:<label id="lblMaxFailHigher">0</label> 
                                          <br />
                                          <footer>
                                              <button class="btn btn-sm btn-secondary" type="button" id="btnCfgMaxMinHigher" style="display:block !important;" onclick="SetMaxMinParameter('Higher');">
                                                  <i class="arrow-right-up-box-line text-info"></i>Max/Min
                                              </button>
                                          </footer>
                                      </blockquote>
                                  </div>
                              </div>
                              <!-- End Param Pass/Fail -->
                          </div>
                      </div>
                  </div>
              </div>
              <div class="row border mb-3 p-2" style="background-color: #f8f9fa;">
                  <div class="col-5">
                      <label id="lblHiestBoxplot">Highest Boxplot</label>
                      <canvas id="ttaHiesBoxPlotChart"></canvas>
                  </div>
                  <div class="col-5">
                      <label id="lblHiestOffBoxplot">Highest Offset</label>
                      <canvas id="ttaHiestOffBoxPlotChart"></canvas>
                  </div>
                  <div class="col-2 border-1 mt-8">
                      <div class="row" style="display:block">
                          <div class="col-md-12">
                              <!-- Start Param Pass/Fail Highest -->
                              <div class="card shadow-lg-hover mt-5">
                                  <div class="card-header">
                                      Highest Max/Min Parameter
                                  </div>
                                  <div class="card-body">
                                      <blockquote class="blockquote mb-0">
                                          Model:<label id="lblCfgSeriesHighest">-</label>
                                          <br />
                                          Min:<label id="lblMinFailHighest">0</label> Max:<label id="lblMaxFailHighest">0</label> 
                                          <br />
                                          <footer>
                                              <button class="btn btn-sm btn-secondary" type="button" id="btnCfgMaxMinHighest" style="display:block !important;" onclick="SetMaxMinParameter('Highest');">
                                                  <i class="arrow-right-up-box-line text-info"></i>Max/Min
                                              </button>
                                          </footer>
                                      </blockquote>
                                  </div>
                              </div>
                              <!-- End Param Pass/Fail -->
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </div>


      <!-- Row1 Lower Zone chart -->
