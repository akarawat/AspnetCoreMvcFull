  "bfodata": -5,
  "aftdata": 5.5,
  "perc": "0%"
  },
  {
    "ddmmyy": "01/02/2025",
    "bfodata": -3,
    "aftdata": 8,
    "perc": "0%"
  },{
    "ddmmyy": "01/03/2025",
    "bfodata": -3.5,
    "aftdata": 4.5,
    "perc": "0%"
  },{
    "ddmmyy": "01/04/2025",
