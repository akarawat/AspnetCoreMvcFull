//--> For Chart
const datas = [{
        type: 'line',
        label: 'Failed limit',
        data: [-5, -3, -3.5, -7, -1],
      borderColor: 'rgb(0, 128, 0)'
          }, {
        type: 'line',
          label: 'Normal',
            data: [1, 1, 1, 1, 1],
              borderColor: 'rgb(140, 87, 255)'
      }, {
        type: 'line',
          label: 'Failed Cut',
            data: [5.5, 8, 4.5, 3, 8.5],
              borderColor: 'rgb(245, 224, 0)'
      }];

const ctx = document.getElementById('myChart');
const mixedChart = new Chart(ctx, {
  label: 'Max thread cut current Dataset',
  data: {
    datasets: datas,
    labels: ['01/01/2025', '01/02/2025', '01/03/2025', '01/04/2025', '01/05/2025']
  },
  options: {
    scales: {
      y: {
        beginAtZero: true,
        min: -20,
        max: 20
      }
    }
  }
});

console.log(mixedChart);
